  "controls": {
    "中文逗號": {
      "morse": "..--.",
      "action": "Punct",
      "char": "，"
    },
    "中文句點": {
      "morse": "---.-",
      "action": "Punct",
      "char": "。"
    },
    "中文問號": {
      "morse": "-...-",
      "action": "Punct",
      "char": "？"
    },
    "驚嘆號": {
      "morse": ".--...",
      "action": "Punct",
      "char": "！"
    },
    "小文書開啟(Reset)": {
      "morse": "-..--",
      "action": "ClearAll"
    },
    "中英切換": {
      "morse": "..--",
      "action": "ToggleMode"
    },
    "← BackSpace": {
      "morse": ".-.-",
      "action": "Backspace"
    },
    "取消拼字": {
      "morse": "..-..",
      "action": "CancelComposing"
    },
    "整頁發音": {
      "morse": ".-----",
      "action": "SpeakAll"
    },
    "開始播放": {
      "morse": "...---",
      "action": "SpeakAll"
    },
    "停止播放": {
      "morse": "-..---",
      "action": "StopSpeak"
    },
    "切換成大/小寫": {
      "morse": "..-.-",
      "action": "ToggleCase"
    },
    "送出（暫定）": {
      "morse": ".-.-.",
      "action": "Submit",
      "note": "真實碼表無送出鍵,此為暫定;待確認馥華原系統如何送出/確認拼字"
    }
  }
